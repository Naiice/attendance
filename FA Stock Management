import React, { useState, useEffect, useRef } from 'react';
import { Search, AlertTriangle, PackagePlus, PackageMinus, Barcode, CheckCircle2, RefreshCw, X, Image as ImageIcon } from 'lucide-react';

// 🔴 นำ URL ของ Google Apps Script ที่ Deploy เสร็จแล้วมาใส่ตรงนี้ 🔴
const SCRIPT_URL = 'https://script.google.com/macros/s/AKfycbxeuvLdQinVWwPwUSDZkX7_aHIU9_nbsKWREJ3yw32vyUpyaZ_PZSYlVl-s4tAN0SY/exec'; 

// Helper แปลง URL รูปภาพจาก Google Drive ให้แสดงผลได้บนเว็บ
const getDirectImageUrl = (url) => {
  if (!url) return null;
  const match = url.match(/\/file\/d\/([a-zA-Z0-9_-]+)/);
  if (match && match[1]) {
    return `https://drive.google.com/uc?id=${match[1]}`;
  }
  return url;
};

export default function StockManagementApp() {
  const [inventory, setInventory] = useState([]);
  const [filteredInventory, setFilteredInventory] = useState([]);
  const [searchTerm, setSearchTerm] = useState('');
  const [isLoading, setIsLoading] = useState(true);
  const [statusMessage, setStatusMessage] = useState({ type: '', text: '' });
  
  // สถานะสำหรับ Modal เติม/เบิก
  const [modalState, setModalState] = useState({
    isOpen: false,
    type: 'IN', // 'IN' หรือ 'OUT'
    itemCode: '',
    qty: 1,
    person: ''
  });
  
  // อ้างอิง Input ของ Scanner เพื่อให้ Auto-focus
  const scannerInputRef = useRef(null);
  const [scannerCode, setScannerCode] = useState('');

  // ฟังก์ชันดึงข้อมูลจาก Google Sheets
  const fetchStockData = async () => {
    setIsLoading(true);
    try {
      // ดักจับการใช้ URL ชั่วคราวเพื่อป้องกัน Error: Failed to fetch
      if (SCRIPT_URL.includes('YOUR_WEB_APP_URL')) {
        throw new Error('DEMO_MODE');
      }
      
      const response = await fetch(`${SCRIPT_URL}?action=getStockData`);
      if (!response.ok) throw new Error('Network error or CORS issue');
      
      const data = await response.json();
      if (data.error) throw new Error(data.error);
      
      setInventory(data);
      setFilteredInventory(data);
      setStatusMessage({ type: 'success', text: 'อัปเดตข้อมูลล่าสุดสำเร็จ' });
      setTimeout(() => setStatusMessage({ type: '', text: '' }), 3000);
    } catch (error) {
      console.error('Error fetching stock:', error);
      
      if (error.message === 'DEMO_MODE' || SCRIPT_URL.includes('YOUR_WEB_APP_URL')) {
        // Mock data สำหรับ Preview ถ้ายังไม่ได้ใส่ URL จริง
        const mockData = [
          { id: 'PD-001', barcode: '885001122', name: 'ไม้กวาด', nameChina: '扫帚', unit: 'Pcs.', picUrl: '', safetyStock: 10, qty: 50 },
          { id: 'PD-002', barcode: '885001123', name: 'เทปเหลืองติดพื้น', nameChina: '', unit: 'Pcs.', picUrl: '', safetyStock: 20, qty: 15 },
          { id: 'PD-003', barcode: '885001124', name: 'กระดาษ A4', nameChina: 'A4纸', unit: 'Ream', picUrl: '', safetyStock: 50, qty: 10 },
        ];
        setInventory(mockData);
        setFilteredInventory(mockData);
        setStatusMessage({ type: 'error', text: '⚠️ กำลังใช้ข้อมูลทดสอบ (กรุณาใส่ SCRIPT_URL ของคุณ)' });
      } else {
        setStatusMessage({ type: 'error', text: 'การเชื่อมต่อล้มเหลว: โปรดตรวจสอบ SCRIPT_URL หรือเช็คสิทธิ์ (Anyone) ใน Apps Script' });
      }
    } finally {
      setIsLoading(false);
    }
  };

  useEffect(() => {
    // โหลดข้อมูลครั้งแรก
    fetchStockData();
  }, []);

  // ระบบค้นหา
  useEffect(() => {
    const results = inventory.filter(item => 
      (item.id && item.id.toLowerCase().includes(searchTerm.toLowerCase())) || 
      (item.name && item.name.toLowerCase().includes(searchTerm.toLowerCase())) ||
      (item.barcode && item.barcode.toLowerCase().includes(searchTerm.toLowerCase()))
    );
    setFilteredInventory(results);
  }, [searchTerm, inventory]);

  // จัดการเมื่อสแกนบาร์โค้ดแล้วกด Enter
  const handleScanSubmit = (e) => {
    e.preventDefault();
    if (!scannerCode) return;

    // ค้นหาสินค้าว่ามีในระบบไหม (หาจาก Barcode ก่อน ถ้าไม่เจอหาจาก Product Code)
    const foundItem = inventory.find(item => 
      (item.barcode && item.barcode === scannerCode) || 
      (item.id && item.id === scannerCode)
    );
    
    if (foundItem) {
      // เปิด Modal ให้เบิกจ่าย (Defaut เป็น OUT) และส่ง Product Code ไปทำรายการ
      setModalState({
        isOpen: true,
        type: 'OUT',
        itemCode: foundItem.id, // ใช้ Product Code เป็นตัวอ้างอิงหลักในการบันทึก
        qty: 1,
        person: ''
      });
    } else {
      setStatusMessage({ type: 'error', text: `ไม่พบรหัสสินค้าหรือบาร์โค้ด: ${scannerCode}` });
      setTimeout(() => setStatusMessage({ type: '', text: '' }), 3000);
    }
    setScannerCode(''); // เคลียร์ช่องสแกน
  };

  // จัดการ Submit Modal (บันทึกข้อมูล)
  const handleTransactionSubmit = async (e) => {
    e.preventDefault();
    if (!modalState.person.trim()) {
      alert("กรุณากรอกชื่อผู้รับผิดชอบ");
      return;
    }

    setIsLoading(true);
    setModalState({ ...modalState, isOpen: false }); // ปิด Modal ทันทีระหว่างโหลด

    const payload = {
      action: 'updateStock',
      itemCode: modalState.itemCode,
      type: modalState.type,
      qty: modalState.qty,
      person: modalState.person
    };

    try {
      if (SCRIPT_URL.includes('YOUR_WEB_APP_URL')) {
        throw new Error("DEMO_MODE");
      }

      const response = await fetch(SCRIPT_URL, {
        method: 'POST',
        body: JSON.stringify(payload),
        headers: { 'Content-Type': 'text/plain;charset=utf-8' } // ใช้ text/plain เลี่ยง CORS
      });
      
      const result = await response.json();
      
      if (result.status === 'success') {
        setStatusMessage({ type: 'success', text: result.message });
        fetchStockData(); // รีเฟรชข้อมูลใหม่
      } else {
        setStatusMessage({ type: 'error', text: result.message });
      }
    } catch (error) {
      console.error('Transaction Error:', error);
      
      // อัพเดท Mock Data ทันทีถ้าเล่นบน Preview 
      if (error.message === "DEMO_MODE" || SCRIPT_URL.includes('YOUR_WEB_APP_URL')) {
         const newInv = inventory.map(item => {
           if(item.id === payload.itemCode) {
             const newQty = payload.type === 'IN' ? item.qty + Number(payload.qty) : item.qty - Number(payload.qty);
             return {...item, qty: newQty};
           }
           return item;
         });
         setInventory(newInv);
         setFilteredInventory(newInv);
         setStatusMessage({ type: 'success', text: `[ทดสอบ] ทำรายการสำเร็จ: ${payload.type} สินค้า ${payload.itemCode}` });
      } else {
         setStatusMessage({ type: 'error', text: 'เกิดข้อผิดพลาดในการเชื่อมต่อ: ตรวจสอบการตั้งค่า Google Apps Script (CORS)' });
      }

    } finally {
      setIsLoading(false);
      setTimeout(() => setStatusMessage({ type: '', text: '' }), 4000);
      if(scannerInputRef.current) scannerInputRef.current.focus();
    }
  };

  // สินค้าที่ต่ำกว่า Safety Stock
  const lowStockItems = inventory.filter(item => item.qty < item.safetyStock);

  return (
    <div className="min-h-screen bg-slate-50 p-4 md:p-8 font-sans">
      <div className="max-w-6xl mx-auto space-y-6">
        
        {/* Header */}
        <div className="flex flex-col md:flex-row justify-between items-center bg-white p-6 rounded-xl shadow-sm border border-slate-100">
          <div>
            <h1 className="text-2xl md:text-3xl font-bold text-slate-800 flex items-center gap-2">
              <PackageMinus className="text-blue-600" /> FA-Stock Management
            </h1>
            <p className="text-slate-500 mt-1">ระบบจัดการสต็อกคงคลังอัจฉริยะ</p>
          </div>
          <button 
            onClick={fetchStockData}
            disabled={isLoading}
            className="mt-4 md:mt-0 px-4 py-2 bg-slate-100 hover:bg-slate-200 text-slate-700 rounded-lg flex items-center gap-2 transition-colors disabled:opacity-50"
          >
            <RefreshCw className={isLoading ? "animate-spin" : ""} size={18} />
            รีเฟรชข้อมูล
          </button>
        </div>

        {/* Status Messages */}
        {statusMessage.text && (
          <div className={`p-4 rounded-lg flex items-center gap-3 ${statusMessage.type === 'error' ? 'bg-red-50 text-red-700 border border-red-200' : 'bg-green-50 text-green-700 border border-green-200'}`}>
            {statusMessage.type === 'error' ? <AlertTriangle size={20} /> : <CheckCircle2 size={20} />}
            <span className="font-medium">{statusMessage.text}</span>
          </div>
        )}

        <div className="grid grid-cols-1 lg:grid-cols-3 gap-6">
          
          {/* ซ้าย: เครื่องมือ & การแจ้งเตือน */}
          <div className="space-y-6">
            
            {/* กล่องสแกนเนอร์ */}
            <div className="bg-white p-6 rounded-xl shadow-sm border border-slate-100">
              <h2 className="text-lg font-bold text-slate-800 mb-4 flex items-center gap-2">
                <Barcode size={20} /> สแกนบาร์โค้ด
              </h2>
              <form onSubmit={handleScanSubmit}>
                <div className="relative">
                  <input
                    ref={scannerInputRef}
                    type="text"
                    placeholder="สแกน หรือ พิมพ์รหัสสินค้าแล้วกด Enter"
                    className="w-full pl-10 pr-4 py-3 border-2 border-blue-100 rounded-lg focus:border-blue-500 focus:ring-0 outline-none transition-all text-slate-700 font-medium"
                    value={scannerCode}
                    onChange={(e) => setScannerCode(e.target.value)}
                    autoFocus
                  />
                  <Barcode className="absolute left-3 top-3.5 text-slate-400" size={20} />
                </div>
                <p className="text-xs text-slate-400 mt-2 text-center">เสียบเครื่องสแกนบาร์โค้ดและยิงเข้าที่ช่องนี้ได้เลย</p>
              </form>
            </div>

            {/* แจ้งเตือน Safety Stock */}
            <div className="bg-white p-6 rounded-xl shadow-sm border border-red-100">
              <h2 className="text-lg font-bold text-red-600 mb-4 flex items-center gap-2">
                <AlertTriangle size={20} /> แจ้งเตือนของใกล้หมด ({lowStockItems.length})
              </h2>
              {lowStockItems.length > 0 ? (
                <div className="space-y-3 max-h-64 overflow-y-auto pr-2">
                  {lowStockItems.map(item => (
                    <div key={item.id} className="bg-red-50 p-3 rounded-lg border border-red-100 flex justify-between items-center">
                      <div>
                        <div className="font-bold text-slate-800 text-sm">{item.name}</div>
                        <div className="text-xs text-slate-500">รหัส: {item.id}</div>
                      </div>
                      <div className="text-right">
                        <div className="text-red-600 font-bold text-lg">{item.qty}</div>
                        <div className="text-xs text-slate-500">ขั้นต่ำ: {item.safetyStock}</div>
                      </div>
                    </div>
                  ))}
                </div>
              ) : (
                <div className="text-center py-6 text-slate-400 flex flex-col items-center">
                  <CheckCircle2 size={32} className="mb-2 text-green-400" />
                  <p>สินค้าคงคลังอยู่ในเกณฑ์ปกติทั้งหมด</p>
                </div>
              )}
            </div>
          </div>

          {/* ขวา: ตารางสต็อก */}
          <div className="lg:col-span-2 bg-white p-6 rounded-xl shadow-sm border border-slate-100">
            <div className="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-6 gap-4">
              <h2 className="text-xl font-bold text-slate-800">รายการสินค้าทั้งหมด</h2>
              
              <div className="relative w-full sm:w-64">
                <Search className="absolute left-3 top-2.5 text-slate-400" size={18} />
                <input
                  type="text"
                  placeholder="ค้นหารหัส หรือ ชื่อสินค้า..."
                  className="w-full pl-9 pr-4 py-2 border border-slate-200 rounded-lg focus:border-blue-500 outline-none text-sm"
                  value={searchTerm}
                  onChange={(e) => setSearchTerm(e.target.value)}
                />
              </div>
            </div>

            <div className="overflow-x-auto">
              <table className="w-full text-left border-collapse">
                <thead>
                  <tr className="bg-slate-50 text-slate-500 text-sm border-y border-slate-200">
                    <th className="p-3 font-medium">รูปภาพ</th>
                    <th className="p-3 font-medium">รหัสสินค้า / บาร์โค้ด</th>
                    <th className="p-3 font-medium">ชื่อสินค้า</th>
                    <th className="p-3 font-medium text-center">คงเหลือ (หน่วย)</th>
                    <th className="p-3 font-medium text-center">จัดการ</th>
                  </tr>
                </thead>
                <tbody className="divide-y divide-slate-100">
                  {isLoading && inventory.length === 0 ? (
                    <tr><td colSpan="5" className="text-center py-10 text-slate-400">กำลังโหลดข้อมูล...</td></tr>
                  ) : filteredInventory.length === 0 ? (
                    <tr><td colSpan="5" className="text-center py-10 text-slate-400">ไม่พบสินค้าที่ค้นหา</td></tr>
                  ) : (
                    filteredInventory.map(item => (
                      <tr key={item.id} className="hover:bg-slate-50 transition-colors">
                        <td className="p-3">
                          {getDirectImageUrl(item.picUrl) ? (
                            <img 
                              src={getDirectImageUrl(item.picUrl)} 
                              alt={item.name} 
                              className="w-12 h-12 object-cover rounded-md border border-slate-200 bg-white" 
                              onError={(e) => { e.target.onerror = null; e.target.style.display='none'; }} 
                            />
                          ) : (
                            <div className="w-12 h-12 bg-slate-100 rounded-md flex items-center justify-center text-slate-400 border border-slate-200">
                               <ImageIcon size={20} />
                            </div>
                          )}
                        </td>
                        <td className="p-3 text-slate-600 font-mono text-sm">
                          <div className="font-bold text-slate-800">{item.id}</div>
                          {item.barcode && <div className="text-xs text-slate-400">บาร์โค้ด: {item.barcode}</div>}
                        </td>
                        <td className="p-3 font-medium text-slate-800">
                          <div>{item.name}</div>
                          {item.nameChina && <div className="text-xs text-slate-500 font-normal">{item.nameChina}</div>}
                        </td>
                        <td className="p-3 text-center">
                          <span className={`inline-block px-3 py-1 rounded-full text-sm font-bold ${
                            item.qty < item.safetyStock ? 'bg-red-100 text-red-700' : 'bg-green-100 text-green-700'
                          }`}>
                            {item.qty} <span className="text-xs font-normal opacity-80 ml-1">{item.unit}</span>
                          </span>
                        </td>
                        <td className="p-3">
                          <div className="flex justify-center gap-2">
                            <button 
                              onClick={() => setModalState({ isOpen: true, type: 'IN', itemCode: item.id, qty: 1, person: '' })}
                              className="p-1.5 bg-blue-50 hover:bg-blue-100 text-blue-600 rounded-md transition-colors tooltip"
                              title="เติมสต็อก"
                            >
                              <PackagePlus size={18} />
                            </button>
                            <button 
                              onClick={() => setModalState({ isOpen: true, type: 'OUT', itemCode: item.id, qty: 1, person: '' })}
                              className="p-1.5 bg-amber-50 hover:bg-amber-100 text-amber-600 rounded-md transition-colors"
                              title="เบิกจ่าย"
                            >
                              <PackageMinus size={18} />
                            </button>
                          </div>
                        </td>
                      </tr>
                    ))
                  )}
                </tbody>
              </table>
            </div>
          </div>
        </div>
      </div>

      {/* Modal เติม/เบิก สินค้า */}
      {modalState.isOpen && (
        <div className="fixed inset-0 bg-slate-900/50 backdrop-blur-sm flex items-center justify-center p-4 z-50">
          <div className="bg-white rounded-2xl w-full max-w-md overflow-hidden shadow-xl animate-in fade-in zoom-in duration-200">
            <div className={`p-4 flex justify-between items-center text-white ${modalState.type === 'IN' ? 'bg-blue-600' : 'bg-amber-500'}`}>
              <h3 className="font-bold text-lg flex items-center gap-2">
                {modalState.type === 'IN' ? <PackagePlus /> : <PackageMinus />}
                {modalState.type === 'IN' ? 'ทำรายการ: เติมสต็อก (IN)' : 'ทำรายการ: เบิกจ่าย (OUT)'}
              </h3>
              <button onClick={() => setModalState({...modalState, isOpen: false})} className="text-white/80 hover:text-white">
                <X size={24} />
              </button>
            </div>
            
            <form onSubmit={handleTransactionSubmit} className="p-6 space-y-4">
              <div>
                <label className="block text-sm font-medium text-slate-700 mb-1">รหัสสินค้า</label>
                <input 
                  type="text" 
                  value={modalState.itemCode} 
                  disabled
                  className="w-full p-2.5 bg-slate-100 border border-slate-200 rounded-lg text-slate-600 font-mono"
                />
                <div className="text-sm font-bold text-slate-800 mt-1">
                  {inventory.find(i => i.id === modalState.itemCode)?.name}
                </div>
              </div>

              <div>
                <label className="block text-sm font-medium text-slate-700 mb-1">จำนวนที่{modalState.type === 'IN' ? 'เติม' : 'เบิก'}</label>
                <input 
                  type="number" 
                  min="1"
                  required
                  value={modalState.qty}
                  onChange={(e) => setModalState({...modalState, qty: e.target.value})}
                  className="w-full p-2.5 border border-slate-300 rounded-lg focus:border-blue-500 outline-none text-lg font-bold"
                />
              </div>

              <div>
                <label className="block text-sm font-medium text-slate-700 mb-1 text-red-600">ชื่อผู้รับผิดชอบ / ผู้เบิก (บังคับ)*</label>
                <input 
                  type="text" 
                  required
                  placeholder="ระบุชื่อพนักงาน"
                  value={modalState.person}
                  onChange={(e) => setModalState({...modalState, person: e.target.value})}
                  className="w-full p-2.5 border-2 border-slate-300 focus:border-red-500 rounded-lg outline-none"
                  autoFocus
                />
              </div>

              <div className="pt-4 flex gap-3">
                <button 
                  type="button"
                  onClick={() => setModalState({...modalState, isOpen: false})}
                  className="flex-1 py-2.5 bg-slate-100 hover:bg-slate-200 text-slate-700 rounded-lg font-medium transition-colors"
                >
                  ยกเลิก
                </button>
                <button 
                  type="submit"
                  className={`flex-1 py-2.5 text-white rounded-lg font-medium transition-colors ${modalState.type === 'IN' ? 'bg-blue-600 hover:bg-blue-700' : 'bg-amber-500 hover:bg-amber-600'}`}
                >
                  ยืนยันบันทึก
                </button>
              </div>
            </form>
          </div>
        </div>
      )}
    </div>
  );
}
